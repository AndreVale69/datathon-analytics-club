# Copy this file to `.env.local` for local development.
# `.env.local` is gitignored and is loaded automatically by the Python app and MCP server.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

LISTINGS_RAW_DATA_DIR=raw_data
LISTINGS_DB_PATH=data/listings.db

LISTINGS_S3_BUCKET=
LISTINGS_S3_REGION=eu-central-2
LISTINGS_S3_PREFIX=prod
GEOCODING_API_BASE_URL=https://api3.geo.admin.ch/rest/services/ech/SearchServer
GEOCODING_TIMEOUT_SECONDS=5.0

APPS_SDK_LISTINGS_API_BASE_URL=http://localhost:8000
APPS_SDK_PUBLIC_BASE_URL=http://localhost:8001
APPS_SDK_PORT=8001

MCP_ALLOWED_HOSTS=
MCP_ALLOWED_ORIGINS=
